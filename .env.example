# ===================================================
#   TS3 Music Bot - Ejemplo de Configuración
# ===================================================

# Copia este archivo como .env y rellena los valores

# --- Servidor TeamSpeak 3 ---
TS3_HOST=192.168.x.x
TS3_QUERY_PORT=10011
TS3_SERVER_PORT=9987
TS3_USERNAME=serveradmin
TS3_PASSWORD=tu_contraseña_aquí

# Nombre con el que aparecerá el bot en el servidor
TS3_NICKNAME=🎵 MusicBot

# (Opcional) ID del canal al que se moverá el bot al iniciar.
TS3_CHANNEL_ID=

# --- Audio ---
DEFAULT_VOLUME=80
